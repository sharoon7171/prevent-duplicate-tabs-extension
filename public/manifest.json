{
  "manifest_version": 3,
  "name": "Prevent Duplicate Tabs",
  "version": "1.6.0",
  "description": "Prevent duplicate tabs from being opened",
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_ui": {
    "open_in_tab": true,
    "page": "options.html"
  },
  "permissions": [
    "contextMenus",
    "storage",
    "tabs",
    "windows"
  ]
}
