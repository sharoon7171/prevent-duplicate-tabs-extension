{
  "name": "prevent-duplicate-tabs",
  "version": "1.7.0",
  "description": "Prevent Duplicate Tabs Chrome Extension",
  "type": "module",
  "scripts": {
    "build": "vite build && BUILD_BACKGROUND=1 vite build",
    "build:zip": "bash scripts/build-zip.sh",
    "dev": "EMPTY_OUT_DIR=0 vite build --watch --mode development & BUILD_BACKGROUND=1 vite build --watch --mode development & wait",
    "type-check": "tsc --noEmit",
    "screenshot": "npm run build && npx playwright install chromium && node scripts/screenshot-options.mjs",
    "screenshot:options": "node scripts/screenshot-options.mjs",
    "screenshot:popup": "node scripts/screenshot-popup-mockup.mjs"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/chrome": "^0.1.42",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13"
  }
}
